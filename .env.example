# ─────────────────────────────────────────────────────────────────────────────
# ILND App — Ortam Değişkenleri Şablonu
# Bu dosyayı kopyala: cp .env.example .env
# Gerçek değerleri Supabase ve Firebase konsollarından doldur.
# Kullanım: flutter run --dart-define-from-file=.env
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://PROJE_REF.supabase.co
SUPABASE_ANON_KEY=eyJ...   # Dashboard → API Keys (Legacy) → anon public

# ── Firebase ──────────────────────────────────────────────────────────────────
FIREBASE_API_KEY=AIza...
FIREBASE_AUTH_DOMAIN=proje-id.firebaseapp.com
FIREBASE_PROJECT_ID=proje-id
FIREBASE_STORAGE_BUCKET=proje-id.firebasestorage.app
FIREBASE_MESSAGING_SENDER_ID=000000000000
FIREBASE_APP_ID=1:000000000000:web:xxxxxxxxxxxx
